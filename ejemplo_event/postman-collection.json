		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Limpiar consola para mejor visualización",
					"console.clear();",
					"console.log('🚀 Demo de Tareas Asíncronas');",
					"console.log('📋 Asegúrate que la aplicación esté corriendo en http://localhost:8080');",
					"console.log('🔄 Flujo recomendado: 1 → 2 → 3 → 2 → 3');"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
