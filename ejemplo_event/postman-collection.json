{
	"info": {
		"_postman_id": "e1v2e3n4-t5s6-7890-simple-async",
		"name": "API Tareas Asíncronas - Demo Simple",
		"description": "Colección simplificada para demostrar procesamiento asíncrono de tareas",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "1. Crear Tarea",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"// Guardar el ID de la tarea para usar en otras peticiones",
							"if (pm.response.code === 200) {",
							"    const response = pm.response.json();",
							"    pm.collectionVariables.set('tareaId', response.tareaId);",
							"    pm.collectionVariables.set('tareaEstado', response.estado);",
							"    ",
							"    console.log('=== TAREA CREADA ===');",
							"    console.log('ID:', response.tareaId);",
							"    console.log('Estado:', response.estado);",
							"    console.log('Mensaje:', response.message);",
							"    ",
							"    // Tests",
							"    pm.test('Status code is 200', function () {",
							"        pm.response.to.have.status(200);",
							"    });",
							"    ",
							"    pm.test('Response has tareaId', function () {",
							"        pm.expect(response).to.have.property('tareaId');",
							"    });",
							"    ",
							"    pm.test('Estado inicial es PENDIENTE', function () {",
							"        pm.expect(response.estado).to.eql('PENDIENTE');",
							"    });",
							"    ",
							"    console.log('✅ Tarea creada - Revisa los logs para ver el procesamiento asíncrono');",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"descripcion\": \"Procesar archivo CSV de ventas\"\n}"
				},
				"url": {
					"raw": "http://localhost:8080/api/tareas",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8080",
					"path": [
						"api",
						"tareas"
					]
				},
				"description": "Crea una nueva tarea. La API responde inmediatamente con 200 OK mientras el procesamiento ocurre en background (5-10 segundos)."
			},
			"response": []
		},
		{
			"name": "2. Consultar Tarea por ID",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const response = pm.response.json();",
							"console.log('=== ESTADO DE TAREA ===');",
							"console.log('ID:', response.id);",
							"console.log('Descripción:', response.descripcion);",
							"console.log('Estado:', response.estado);",
							"console.log('Fecha Creación:', response.fechaCreacion);",
							"console.log('Fecha Procesamiento:', response.fechaProcesamiento);",
							"console.log('Resultado:', response.resultado);",
							"console.log('Error:', response.errorMensaje);",
							"",
							"pm.test('Status code is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test('Response has required fields', function () {",
							"    pm.expect(response).to.have.property('id');",
							"    pm.expect(response).to.have.property('descripcion');",
							"    pm.expect(response).to.have.property('estado');",
							"    pm.expect(response).to.have.property('fechaCreacion');",
							"});",
							"",
							"pm.test('Estado es válido', function () {",
							"    const estadosValidos = ['PENDIENTE', 'PROCESANDO', 'COMPLETADA', 'ERROR'];",
							"    pm.expect(estadosValidos).to.include(response.estado);",
							"});",
							"",
							"// Mostrar mensaje según el estado",
							"if (response.estado === 'PENDIENTE') {",
							"    console.log('⏳ La tarea está esperando ser procesada');",
							"} else if (response.estado === 'PROCESANDO') {",
							"    console.log('🔄 La tarea está siendo procesada ahora');",
							"} else if (response.estado === 'COMPLETADA') {",
							"    console.log('✅ La tarea fue completada exitosamente');",
							"} else if (response.estado === 'ERROR') {",
							"    console.log('❌ La tarea falló durante el procesamiento');",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:8080/api/tareas/{{tareaId}}",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8080",
					"path": [
						"api",
						"tareas",
						"{{tareaId}}"
					]
				},
				"description": "Consulta el estado de una tarea específica usando su ID. Ideal para verificar el progreso del procesamiento asíncrono."
			},
			"response": []
		},
		{
			"name": "3. Listar Todas las Tareas",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const response = pm.response.json();",
							"const tareas = Object.values(response);",
							"console.log('=== TODAS LAS TAREAS ===');",
							"console.log('Total de tareas:', tareas.length);",
							"",
							"// Contar tareas por estado",
							"const estados = tareas.reduce((acc, tarea) => {",
							"    acc[tarea.estado] = (acc[tarea.estado] || 0) + 1;",
							"    return acc;",
							"}, {});",
							"",
							"console.log('Tareas por estado:');",
							"Object.entries(estados).forEach(([estado, count]) => {",
							"    console.log(`  ${estado}: ${count}`);",
							"});",
							"",
							"// Mostrar detalles de cada tarea",
							"tareas.forEach((tarea, index) => {",
							"    console.log(`\\nTarea ${index + 1}:`);",
							"    console.log(`  ID: ${tarea.id}`);",
							"    console.log(`  Descripción: ${tarea.descripcion}`);",
							"    console.log(`  Estado: ${tarea.estado}`);",
							"    if (tarea.resultado) {",
							"        console.log(`  Resultado: ${tarea.resultado}`);",
							"    }",
							"});",
							"",
							"pm.test('Status code is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test('Response is an object', function () {",
							"    pm.expect(response).to.be.an('object');",
							"});",
							"",
							"pm.test('Each task has required fields', function () {",
							"    tareas.forEach(tarea => {",
							"        pm.expect(tarea).to.have.property('id');",
							"        pm.expect(tarea).to.have.property('descripcion');",
							"        pm.expect(tarea).to.have.property('estado');",
							"        pm.expect(tarea).to.have.property('fechaCreacion');",
							"    });",
							"});",
							"",
							"pm.test('At least one task exists', function () {",
							"    pm.expect(tareas.length).to.be.at.least(0);",
							"});",
							"",
							"console.log('\\n💡 Tip: Ejecuta varias veces \"Crear Tarea\" y luego consulta esta lista para ver el procesamiento concurrente');"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:8080/api/tareas",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8080",
					"path": [
						"api",
						"tareas"
					]
				},
				"description": "Lista todas las tareas creadas con su estado actual. Perfecto para ver múltiples tareas procesándose en paralelo."
			},
			"response": []
		}
	],
	"variable": [
		{
			"key": "tareaId",
			"value": "",
			"type": "string"
		},
		{
			"key": "tareaEstado",
			"value": "",
			"type": "string"
		}
	],
