	"item": [
		{
			"name": "1. Info Sistema",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const response = pm.response.json();",
							"console.log('=== INFO SISTEMA ===');",
							"console.log('Servicio:', response.servicio);",
							"console.log('Concepto:', response.concepto);",
							"console.log('Tecnología:', response.tecnologia);",
							"console.log('Cola:', response.cola);",
							"",
							"pm.test('Status code is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test('System info available', function () {",
							"    pm.expect(response).to.have.property('servicio');",
							"    pm.expect(response).to.have.property('concepto');",
							"    pm.expect(response).to.have.property('tecnologia');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:8081/api/info",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8081",
					"path": [
						"api",
						"info"
					]
				},
				"description": "Verifica que el sistema esté funcionando correctamente"
			},
			"response": []
		},
		{
			"name": "2. Enviar Mensaje Simple",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const response = pm.response.json();",
							"console.log('=== MENSAJE ENVIADO ===');",
							"console.log('Mensaje:', response.contenido);",
							"console.log('Estado:', response.estado);",
							"console.log('Respuesta:', response.message);",
							"",
							"pm.test('Status code is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test('Message sent successfully', function () {",
							"    pm.expect(response).to.have.property('message');",
							"    pm.expect(response).to.have.property('contenido');",
							"    pm.expect(response).to.have.property('estado', 'EN_COLA');",
							"});",
							"",
							"pm.test('Content is not empty', function () {",
							"    pm.expect(response.contenido).to.be.a('string');",
							"    pm.expect(response.contenido.length).to.be.greaterThan(0);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"contenido\": \"Hola mundo desde la cola - mensaje de prueba\"\n}"
				},
				"url": {
					"raw": "http://localhost:8081/api/enviar",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8081",
					"path": [
						"api",
						"enviar"
					]
				},
				"description": "Envía un mensaje simple a la cola. Revisa los logs del consumidor para ver el procesamiento."
			},
			"response": []
		},
		{
			"name": "3. Demo con 3 Mensajes",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const response = pm.response.json();",
							"console.log('=== DEMO EJECUTADA ===');",
							"console.log('Mensajes enviados:', response.mensajes_enviados);",
							"console.log('Instrucción:', response.instruccion);",
							"",
							"pm.test('Status code is 200', function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test('Demo executed successfully', function () {",
							"    pm.expect(response).to.have.property('message', 'Demo simple ejecutada');",
							"    pm.expect(response).to.have.property('mensajes_enviados', '3');",
							"    pm.expect(response).to.have.property('instruccion');",
							"});",
							"",
							"console.log('👆 Ahora revisa los logs de la aplicación para ver los 3 mensajes siendo procesados');"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"url": {
					"raw": "http://localhost:8081/api/demo",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8081",
					"path": [
						"api",
						"demo"
					]
				},
				"description": "Ejecuta una demostración automática enviando 3 mensajes a la cola. Perfecto para ver el sistema en acción."
			},
			"response": []
		},
